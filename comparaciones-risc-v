.data
.text
.globl main
main:
    li x1,2
    li x2,3
    li x4,2
    bne x1,x2,entra # distinto 
    ecall
    
    entra:
        li x3,3
    beq x1,x4,entra2 # igual 
        ecall
    entra2:
        mul x2,x2,x4
    blt x1,x2,entra3 # x1<x2
        ecall
    entra3:
        div x2,x2,x2
    
    #------ etiqueta fin -------
    beq x1,x2,salto4
        j fin
    
    salto4:
        ecall
fin:
    add x2,x3,x4       
    
